# Copy this file to .env.local and fill in your values.
# Expo reads EXPO_PUBLIC_* variables at build time and makes them
# available via process.env.EXPO_PUBLIC_*.
# .env.local is listed in .gitignore — never commit real keys.

# Google Maps / Places API key
# Required APIs in Google Cloud Console:
#   Maps SDK for Android, Maps SDK for iOS, Places API, Geocoding API
# Restrict the key by package name + SHA-1 fingerprint to limit abuse.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Sentry DSN – get it from https://sentry.io → your project → Settings → Client Keys
EXPO_PUBLIC_SENTRY_DSN=https://your_key@oXXX.ingest.sentry.io/XXXXXX

# Sentry Auth Token – get it from https://sentry.io → Settings → Auth Tokens
# Scopes required: project:releases, org:read
# Must also be set as an EAS Secret: npx eas-cli secret:create --scope project --name SENTRY_AUTH_TOKEN --value "sntrys_..."
SENTRY_AUTH_TOKEN=sntrys_your_auth_token_here
