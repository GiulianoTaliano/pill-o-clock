{
  "inputs": [
    {
      "type": "promptString",
      "id": "github_token",
      "description": "GitHub Personal Access Token — needs scopes: repo, issues, pull_requests, read:org",
      "password": true
    }
  ],
  "servers": {
    "github": {
      "type": "stdio",
      "command": "C:\\Users\\giuli\\AppData\\Local\\github-mcp-server\\github-mcp-server.exe",
      "args": [
        "stdio",
        "--toolsets", "default,actions,code_security,labels,notifications"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${input:github_token}"
      }
    }
  }
}
