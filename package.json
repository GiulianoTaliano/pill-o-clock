{
  "name": "pill-o-clock",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "validate:android": "expo prebuild --platform android --clean --no-install && node -e \"const s=require('fs').readFileSync('android/sentry.properties','utf8');const ok=/^defaults\\.org=\\S+/m.test(s)&&/^defaults\\.project=\\S+/m.test(s);if(!ok){console.error('ERROR: android/sentry.properties is missing defaults.org or defaults.project');process.exit(1)}console.log('sentry.properties OK');if(!process.env.SENTRY_AUTH_TOKEN){console.warn('WARNING: SENTRY_AUTH_TOKEN is not set — EAS cloud build will fail at source map upload. Add it as an EAS Secret.')};\" && cd android && .\\gradlew :expo-alarm:compileReleaseKotlin && cd .."
  },
