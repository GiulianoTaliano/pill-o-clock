<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

  <!-- Required for playing audio + waking the screen -->
  <uses-permission android:name="android.permission.WAKE_LOCK" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
  <!-- API 34+: foreground service type for audio playback -->
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
  <!-- Show alarm screen above the lock screen / other apps -->
  <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
  <!-- Re-arm alarms after a device reboot (AlarmManager clears them on boot) -->
  <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

  <application>

    <!--
      AlarmReceiver: triggered by AlarmManager.setAlarmClock().
      exported=false: only accessible via explicit PendingIntent from this package.
    -->
    <receiver
      android:name="expo.modules.alarm.AlarmReceiver"
      android:exported="false" />

    <!--
      AlarmAudioService: ForegroundService that plays alarm.wav on STREAM_ALARM
      and displays the fullScreenIntent notification.
      foregroundServiceType="mediaPlayback" required on API 34+.
    -->
    <service
      android:name="expo.modules.alarm.AlarmAudioService"
      android:exported="false"
      android:foregroundServiceType="mediaPlayback" />

    <!--
      AlarmActionReceiver: handles Take / Snooze / Skip quick-action button
      taps from the alarm notification.
      exported=false: only reachable via explicit PendingIntent from this package.
    -->
    <receiver
      android:name="expo.modules.alarm.AlarmActionReceiver"
      android:exported="false" />

    <!--
      BootReceiver: re-arms all future alarms after a reboot / app update.
      exported=true is required because these are system broadcasts delivered
      from outside the app. Guarded by RECEIVE_BOOT_COMPLETED (audit C4).
    -->
    <receiver
      android:name="expo.modules.alarm.BootReceiver"
      android:enabled="true"
      android:exported="true">
      <intent-filter>
        <action android:name="android.intent.action.BOOT_COMPLETED" />
        <action android:name="android.intent.action.QUICKBOOT_POWERON" />
        <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
      </intent-filter>
    </receiver>

  </application>

</manifest>
