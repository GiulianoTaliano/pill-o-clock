# Auto-detect text files and normalize line endings to LF in the repo
* text=auto eol=lf

# Windows-specific files
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.wav binary
*.mp3 binary
*.aac binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.zip binary
*.apk binary
*.aab binary
*.ipa binary
